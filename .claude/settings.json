{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Project Status ===' && git status -s && echo '\n=== Type Check (first 15 errors) ===' && pnpm tsc --noEmit 2>&1 | head -15 || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm biome:check:fix $CLAUDE_FILE_PATHS"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm tsc 2>&1 | head -30 || true"
          }
        ]
      }
    ]
  }
}
