{
  "name": "personal-website",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "homepage": "/",
  "scripts": {
    "start": "vite",
    "build": "rimraf dist && vite build",
    "biome:check": "biome check ./src",
    "biome:check:fix": "biome check ./src --write --unsafe",
    "tsc": "tsc",
    "quality": "bun biome:check && bun tsc"
  },
  "dependencies": {
    "dayjs": "1.11.19",
    "es-toolkit": "1.44.0",
    "lucide-solid": "0.575.0",
    "solid-js": "1.9.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "25.3.3",
    "daisyui": "5.5.19",
    "postcss": "8.5.6",
    "rimraf": "6.1.3",
    "rollup-plugin-visualizer": "7.0.0",
    "solid-devtools": "0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-solid": "2.11.10"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
